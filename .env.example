# =============================================================================
# Tripgent — single file for local dev (copy to `.env` at this repo root).
# Vercel: set the same keys in the project Environment Variables UI (no file).
#
# If Vercel "Deployment Protection" returns HTML "Authentication Required" for /health:
# disable protection for previews, OR enable "Protection Bypass for Automation" in the project;
# Vercel then sets VERCEL_AUTOMATION_BYPASS_SECRET and the admin server adds the bypass header.
# =============================================================================

# --- API server (standalone `pnpm dev:api` only; default 8787) ---
# PORT=8787

# --- Chat — 0G Compute direct proxy (OpenAI-shaped: baseURL …/v1/proxy + Bearer app-sk-) ---
ZG_COMPUTE_PROXY_URL=https://compute-network-6.integratenetwork.work/v1/proxy
ZG_COMPUTE_SECRET=app-sk-your-secret-here
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# --- Chat — generic OpenAI-compatible (only if ZG_COMPUTE_PROXY_URL is NOT set) ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# --- Chat — 0G broker SDK (only if no proxy / no OPENAI_API_KEY above) ---
RPC_URL=https://evmrpc-testnet.0g.ai
PRIVATE_KEY=
PROVIDER_ADDRESS=

# Optional: require this Bearer on /v1/chat (dev shortcut; verify Dynamic JWT in prod)
# API_AUTH_BEARER=

# Monaco anon rewards: default wallet is built into the API unless you override or disable:
# REWARD_FALLBACK_WALLET_ADDRESS=0xYourWallet
# REWARD_FALLBACK_DISABLED=1

CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Supabase (run apps/api/supabase/migrations in order: 001, 002, 003, 004) ---
SUPABASE_URL=https://xxxx.supabase.co
# Must be the service_role secret (Settings → API), NOT the anon public key — anon + RLS = empty reads.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: protect /v1/admin/* and rewards admin paths
# ADMIN_API_KEY=

# --- Circle Gateway — optional USDC mint to traveler wallet after Monaco pool accrual ---
# See https://developers.circle.com/gateway/quickstarts/unified-balance-evm (treasury deposits + transfer/mint).
# Nanopayments x402 (https://developers.circle.com/gateway/nanopayments) is buyer→seller; paying users uses Gateway mint below.
# CIRCLE_GATEWAY_REWARD_ENABLED=true
# CIRCLE_API_KEY=
# CIRCLE_ENTITY_SECRET=
# CIRCLE_GATEWAY_TREASURY_WALLET_ADDRESS=0x...   # Circle Developer-Controlled Wallet on ARC-TESTNET with Gateway balance
# CIRCLE_GATEWAY_API_URL=https://gateway-api-testnet.circle.com
# CIRCLE_GATEWAY_MIN_USDC=0.000001

# --- Admin (Next) — only if API is on another origin ---
# TRIPGENT_API_URL=http://127.0.0.1:8787
# NEXT_PUBLIC_TRIPGENT_API_URL=
# NEXT_PUBLIC_ADMIN_API_KEY=

# --- Mobile (Expo) — loaded via dotenv-cli from this root `.env` ---
EXPO_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
EXPO_PUBLIC_DYNAMIC_APP_ORIGIN=http://localhost:8081
# Chat API base (no trailing slash). Simulator: 127.0.0.1 OK. Physical device: use your PC's LAN IP.
# Next admin dev (:3000) rewrites /v1/* to Hono. Standalone: pnpm dev:api (:8787) — set http://<LAN>:8787
EXPO_PUBLIC_TRIPGENT_API_URL=http://127.0.0.1:3000
# EXPO_PUBLIC_API_AUTH_BEARER=
# Override mobile default reward wallet (optional; app matches API built-in default)
# EXPO_PUBLIC_REWARD_FALLBACK_WALLET_ADDRESS=0x...
