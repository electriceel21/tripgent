{
  "name": "@tripgent/mobile",
  "description": "Customer mobile app — Tripgent chatbot (Dynamic auth, 0G via API, Circle rewards TBD)",
  "version": "0.0.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@react-native-community/cli",
      "react-native",
      "esbuild"
    ]
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "dotenv -e ../../.env -- expo start",
    "android": "dotenv -e ../../.env -- expo start --android",
    "ios": "dotenv -e ../../.env -- expo start --ios",
    "lint": "tsc --noEmit",
    "eas:init": "eas init",
    "eas:build:android": "eas build -p android --profile preview"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.0",
    "@dynamic-labs/client": "^4.67.2",
    "@dynamic-labs/react-hooks": "^4.75.0",
    "@dynamic-labs/react-native-extension": "^4.75.0",
    "@dynamic-labs/viem-extension": "^4.75.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-linking": "~7.0.5",
    "expo-modules-core": "~2.2.3",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-webview": "13.12.5",
    "viem": "^2.45.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~18.3.12",
    "dotenv-cli": "^7.4.4",
    "eas-cli": "^16.19.0",
    "typescript": "^5.7.2"
  }
}
