# Dynamic — https://app.dynamic.xyz/dashboard/developer
EXPO_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
# Required by Dynamic (allowlist same origin in dashboard → Security → Allowed Origins)
EXPO_PUBLIC_DYNAMIC_APP_ORIGIN=http://localhost:8081

# Local: unified Next+API on port 3000, or standalone API on 8787 (pnpm dev:api)
# Production: https://your-app.vercel.app
EXPO_PUBLIC_TRIPGENT_API_URL=http://127.0.0.1:3000
# Dev only: shared secret with API when not using Dynamic JWT yet
EXPO_PUBLIC_API_AUTH_BEARER=
