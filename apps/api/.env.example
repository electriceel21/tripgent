# =============================================================================
# Chat — 0G Compute DIRECT PROXY (OpenAI SDK shape: baseURL .../v1/proxy + Bearer app-sk-)
# From: 0g-compute-cli inference get-secret --provider <PROVIDER_ADDRESS>
# =============================================================================
ZG_COMPUTE_PROXY_URL=https://compute-network-6.integratenetwork.work/v1/proxy
ZG_COMPUTE_SECRET=app-sk-your-secret-here
ZG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# =============================================================================
# Chat — generic OpenAI-compatible (only if ZG_COMPUTE_PROXY_URL is NOT set)
# =============================================================================
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Chat — 0G broker SDK path (only if NO proxy secret / no OPENAI_API_KEY above)
# =============================================================================
RPC_URL=https://evmrpc-testnet.0g.ai
PRIVATE_KEY=
PROVIDER_ADDRESS=

# Optional: require this exact Bearer value (dev shortcut)
# API_AUTH_BEARER=

CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Supabase — run supabase/migrations/001_tripgent.sql in SQL editor
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ADMIN_API_KEY=
